{
  "openapi": "3.1.0",
  "info": {
    "title": "Referendum 2030 API",
    "version": "1.0.0"
  },
  "paths": {
    "/api/v1/healthz": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "API is available"
          }
        }
      }
    },
    "/api/v1/referendums/current": {
      "get": {
        "summary": "Current referendum",
        "responses": {
          "200": {
            "description": "Current public referendum"
          }
        }
      }
    },
    "/api/v1/referendums/{slug}": {
      "get": {
        "summary": "Referendum detail",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Referendum detail"
          }
        }
      }
    },
    "/api/v1/referendums/{slug}/tokens": {
      "post": {
        "summary": "Issue demo token",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Plain demo token returned once"
          }
        }
      }
    },
    "/api/v1/referendums/{slug}/vote": {
      "post": {
        "summary": "Cast demo vote",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Demo vote receipt"
          },
          "409": {
            "description": "Token already used"
          }
        }
      }
    },
    "/api/v1/referendums/{slug}/results": {
      "get": {
        "summary": "Aggregate results",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Aggregate totals only"
          }
        }
      }
    },
    "/api/v1/referendums/{slug}/audit": {
      "get": {
        "summary": "Public audit events",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Public safe audit events"
          }
        }
      }
    }
  }
}


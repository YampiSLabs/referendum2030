# Copy to .env.prod on the VPS and change every secret/domain value.

POSTGRES_DB=referendum2030
POSTGRES_USER=referendum2030
POSTGRES_PASSWORD=change-this-postgres-password

DJANGO_SETTINGS_MODULE=referendum2030.settings.production
SECRET_KEY=change-this-to-a-long-random-django-secret-key
API_PORT=8000
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-api-domain.example.com
CORS_ALLOWED_ORIGINS=https://cdryampi.github.io
CSRF_TRUSTED_ORIGINS=https://your-api-domain.example.com,https://cdryampi.github.io
DATABASE_URL=postgres://referendum2030:change-this-postgres-password@db:5432/referendum2030

# Keep false for first HTTP smoke test on server IP. Set true after HTTPS works.
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Set to 31536000 only after HTTPS is permanent.
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

DEMO_ADMIN_USERNAME=admin
DEMO_ADMIN_PASSWORD=admin
DEMO_ADMIN_EMAIL=admin@example.test

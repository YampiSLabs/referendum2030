# Copy to .env.prod on the VPS and change every secret/domain value.

POSTGRES_DB=referendum2030
POSTGRES_USER=referendum2030
POSTGRES_PASSWORD=change-this-postgres-password

DJANGO_SETTINGS_MODULE=referendum2030.settings.production
SECRET_KEY=change-this-to-a-long-random-django-secret-key
API_PORT=8000
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,referendum.yampi.eu
CORS_ALLOWED_ORIGINS=https://yampislabs.github.io
CSRF_TRUSTED_ORIGINS=https://referendum.yampi.eu,https://yampislabs.github.io
DATABASE_URL=postgres://referendum2030:change-this-postgres-password@db:5432/referendum2030

# =====================
# Security / hardening
# =====================
# Traefik handles HTTPS redirect at the proxy level, so SECURE_SSL_REDIRECT=False.
# Django reads SECURE_PROXY_SSL_HEADER (HTTP_X_FORWARDED_PROTO) to detect HTTPS.
# All three below = True in production once HTTPS is confirmed working.
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# HSTS: start with a low max-age, then increase once stable.
# 31536000 = 1 year (standard for preload).
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=False

# Django defaults already enforce:
# - X-Content-Type-Options: nosniff
# - X-Frame-Options: DENY
# - Referrer-Policy: same-origin
# - SECURE_PROXY_SSL_HEADER = ("HTTP_X_FORWARDED_PROTO", "https")

DEMO_ADMIN_USERNAME=yampi
DEMO_ADMIN_PASSWORD=thos
DEMO_ADMIN_EMAIL=yampi@example.test

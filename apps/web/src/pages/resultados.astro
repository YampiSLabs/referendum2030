---
import BaseLayout from "../layouts/BaseLayout.astro";
import ResultsWidget from "../components/react/ResultsWidget";
---

<BaseLayout title="Resultats | Referèndum 2030" description="Resultats agregats del simulador fictici.">
  <section class="container py-12">
    <div class="mb-8 max-w-3xl">
      <h1 class="text-4xl font-black">Resultats agregats</h1>
      <p class="mt-3 leading-7 text-[var(--muted)]">
        Visualització pública de totals demo. No es mostra cap dada individual de vot.
      </p>
    </div>
    <ResultsWidget client:load />
  </section>
</BaseLayout>


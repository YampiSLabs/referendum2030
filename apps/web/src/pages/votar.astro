---
import BaseLayout from "../layouts/BaseLayout.astro";
import VoteWidget from "../components/react/VoteWidget";
---

<BaseLayout title="Votar | Referèndum 2030" description="Emet un vot demo amb token fictici.">
  <section class="container py-12">
    <div class="mb-8 max-w-3xl">
      <h1 class="text-4xl font-black">Vot demo</h1>
      <p class="mt-3 leading-7 text-[var(--muted)]">
        Genera un token fictici, tria una opció i confirma el vot. No introdueixis cap dada personal real.
      </p>
    </div>
    <VoteWidget client:load />
  </section>
</BaseLayout>


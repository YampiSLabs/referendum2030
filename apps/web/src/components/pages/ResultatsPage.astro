---
import PageShell from "../astro/PageShell.astro";
import PageHero from "../astro/PageHero.astro";
import ResultsWidget from "../../features/results/ui/ResultsWidget";
import { getRoute, withBase } from "../../shared/lib/routes";
import { useTranslations } from "../../shared/i18n/translations";
import type { Locale } from "../../shared/i18n/translations";

interface Props {
  lang?: Locale;
}

const { lang = "ca" } = Astro.props;
const t = useTranslations(lang);
---

<PageShell lang={lang} title={t("meta.results.title")} description={t("meta.results.description")}>
  
  <!-- Header Page Row -->
  <PageHero 
    title={t("results.hero.title")} 
    description={t("results.hero.description")}
    showDisclaimer={true}
    lang={lang}
  />

  <!-- Interactive Results Section -->
  <section class="container pb-16">
    <ResultsWidget client:only="react" lang={lang} />
  </section>

  <!-- Open Data & Auditability Sector -->
  <section id="dades-obertes" class="bg-crema-dark border-t border-b border-line py-16">
    <div class="container grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
      
      <!-- Narrative Left Column -->
      <div class="lg:col-span-6 flex flex-col gap-4">
        <div class="flex items-center gap-3">
          <div class="p-2.5 bg-brand-red/5 rounded-xl text-brand-red" aria-hidden="true">
            <svg class="w-5.5 h-5.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0v3.75m-16.5-3.75v3.75"></path>
            </svg>
          </div>
          <span class="text-[10px] font-black tracking-widest text-brand-red uppercase">{t("results.audit.badge")}</span>
        </div>
        
        <h2 class="font-outfit text-2xl md:text-3xl font-extrabold text-gray-900 leading-tight mt-1">
          {t("results.audit.title")}
        </h2>
        
        <p class="text-xs text-muted leading-relaxed font-semibold max-w-lg mt-1">
          {t("results.audit.body")}
        </p>

        <!-- Inline alert note about privacy -->
        <div class="flex items-start gap-2 border border-line bg-white/70 p-3.5 rounded-lg text-[10.5px] text-muted font-bold max-w-lg mt-2">
          <svg class="w-4.5 h-4.5 text-brand-red flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"></path>
          </svg>
          <span>{t("results.audit.warning")}</span>
        </div>
      </div>

      <!-- Action Box Right Column -->
      <div class="lg:col-span-6 flex justify-center lg:justify-end">
        <article class="panel p-6 sm:p-8 bg-white max-w-md w-full flex flex-col gap-6 shadow-md border-line/65">
          <div class="flex flex-col gap-1.5">
            <h3 class="font-outfit text-sm font-black text-gray-900">{t("results.audit.download.title")}</h3>
            <p class="text-[11px] text-muted font-medium">
              {t("results.audit.download.subtitle")}
            </p>
          </div>

          <!-- Simulation download anchor -->
          <a 
            class="btn w-full min-h-[48px]" 
            href={withBase("/vots-anonims-referendum2030.json")} 
            download="vots-anònims-referendum2030.json"
            onclick={`event.preventDefault(); alert("${t("results.audit.alert")}")`}
            aria-label={t("results.audit.download.aria")}
          >
            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"></path>
            </svg>
            {t("results.audit.download.btn")}
          </a>

          <div class="border-t border-line/65 pt-4 flex justify-between items-center text-[10.5px] font-bold text-muted">
            <a href={`${getRoute("resultats", lang)}#audit-ledger`} class="text-brand-red hover:underline flex items-center gap-1">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"></path>
              </svg>
              {t("results.audit.auditLink")}
            </a>
          </div>
        </article>
      </div>

    </div>
  </section>

</PageShell>

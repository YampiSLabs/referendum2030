---
import PageShell from "../astro/PageShell.astro";
import PageHero from "../astro/PageHero.astro";
import VoteWidget from "../../features/voting/ui/VoteWidget";
import FaqAccordion from "../astro/FaqAccordion.astro";
import { useTranslations } from "../../shared/i18n/translations";
import type { Locale } from "../../shared/i18n/translations";

interface Props {
  lang?: Locale;
}

const { lang = "ca" } = Astro.props;
const t = useTranslations(lang);
---

<PageShell lang={lang} title={t("meta.votar.title")} description={t("meta.votar.description")}>
  
  <!-- Header Page Row -->
  <PageHero 
    title={t("vote.hero.title")} 
    description={t("vote.hero.description")}
    showDisclaimer={true}
    lang={lang}
  />

  <!-- Main Body Grid Layout -->
  <section class="container pb-16">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      
      <!-- Left Column (8 cols): Interactive React voting widget island -->
      <div class="lg:col-span-8 flex flex-col gap-6">
        <VoteWidget client:only="react" lang={lang} />
      </div>

      <!-- Right Column (4 cols): Security indicators and FAQ contextual shortcuts -->
      <aside class="lg:col-span-4 flex flex-col gap-6">
        
        <!-- Cabin Guarantees Panel -->
        <article class="panel p-6 bg-gradient-to-br from-white to-crema-dark/25">
          <div class="flex items-center gap-3.5 mb-4">
            <div class="p-2 bg-brand-red/5 rounded-xl text-brand-red" aria-hidden="true">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"></path>
              </svg>
            </div>
            <h2 class="font-outfit text-sm font-black text-gray-900">{t("vote.aside.title")}</h2>
          </div>
          
          <p class="text-xs text-muted leading-relaxed font-semibold">
            {t("vote.aside.body")}
          </p>

          <ul class="flex flex-col gap-3 mt-4.5 text-xs font-semibold text-gray-800">
            <li class="flex items-start gap-2.5">
              <svg class="w-4 h-4 text-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"></path>
              </svg>
              <span>{t("vote.aside.guarantee1")}</span>
            </li>
            <li class="flex items-start gap-2.5">
              <svg class="w-4 h-4 text-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"></path>
              </svg>
              <span>{t("vote.aside.guarantee2")}</span>
            </li>
            <li class="flex items-start gap-2.5">
              <svg class="w-4 h-4 text-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"></path>
              </svg>
              <span>{t("vote.aside.guarantee3")}</span>
            </li>
          </ul>

          <div class="border-t border-line/65 pt-4 mt-5 flex justify-between items-center text-[10px] font-bold text-muted">
            <span>{t("vote.aside.status")}</span>
            <span class="text-green flex items-center gap-1 font-bold">
              <span class="w-1.5 h-1.5 rounded-full bg-green animate-pulse" aria-hidden="true"></span>
              {t("vote.aside.active")}
            </span>
          </div>
        </article>

        <!-- Help shortcuts -->
        <div class="flex flex-col gap-3">
          <h3 class="font-outfit text-xs font-black tracking-wider text-ink uppercase pl-1">{t("vote.aside.help")}</h3>
          
          <FaqAccordion 
            question={t("vote.aside.faq1.q")}
            answer={t("vote.aside.faq1.a")}
          />
          
          <FaqAccordion 
            question={t("vote.aside.faq2.q")}
            answer={t("vote.aside.faq2.a")}
          />
        </div>

      </aside>

    </div>
  </section>

</PageShell>

---
import { useTranslations } from "../../shared/i18n/translations";
import type { Locale } from "../../shared/i18n/translations";

interface Props {
  totalVotes?: number;
  isOpen?: boolean;
  lang?: Locale;
}

const { 
  totalVotes = 245730, 
  isOpen = true,
  lang = "ca"
} = Astro.props;

const t = useTranslations(lang);

// Format number locally matching the active locale
const formatNumber = (num: number) => {
  const localeMap = {
    ca: "ca-ES",
    es: "es-ES",
    en: "en-US",
    fr: "fr-FR",
    ar: "ar-EG", // Formatted nicely in Arabic standard
    zh: "zh-CN"
  };
  return new Intl.NumberFormat(localeMap[lang] || "ca-ES").format(num);
};
---

<section class="container pb-16">
  <div class="panel grid grid-cols-1 md:grid-cols-4 gap-6 md:gap-2 p-6 md:p-8 divide-y md:divide-y-0 md:divide-x divide-line/60">
    
    <!-- Metric 1: Estat Actual -->
    <div class="flex items-start gap-4 pb-6 md:pb-0 md:px-4 first:pl-0">
      <div class="p-3.5 bg-crema-dark rounded-xl text-brand-red flex-shrink-0" aria-hidden="true">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"></path>
        </svg>
      </div>
      <div class="flex flex-col gap-1">
        <span class="text-[10px] font-black tracking-wider text-muted uppercase">{t("status.summary.currentStatus")}</span>
        <div class="flex items-center gap-2 mt-1">
          {isOpen ? (
            <>
              <span class="w-2.5 h-2.5 rounded-full bg-green animate-pulse" aria-hidden="true"></span>
              <span class="text-xl font-bold text-green leading-none">{t("status.summary.open")}</span>
            </>
          ) : (
            <>
              <span class="w-2.5 h-2.5 rounded-full bg-brand-red" aria-hidden="true"></span>
              <span class="text-xl font-bold text-brand-red leading-none">{t("status.summary.closed")}</span>
            </>
          )}
        </div>
        <span class="text-xs text-muted font-medium mt-1">
          {isOpen ? t("status.summary.openText") : t("status.summary.closedText")}
        </span>
      </div>
    </div>

    <!-- Metric 2: Inici -->
    <div class="flex items-start gap-4 pt-6 md:pt-0 md:px-6">
      <div class="p-3.5 bg-crema-dark rounded-xl text-muted flex-shrink-0" aria-hidden="true">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
      </div>
      <div class="flex flex-col gap-0.5">
        <span class="text-[10px] font-black tracking-wider text-muted uppercase">{t("status.summary.start")}</span>
        <span class="text-base font-bold text-ink mt-1.5 leading-none">{t("status.summary.date.start")}</span>
        <span class="text-sm font-bold text-brand-red mt-1">09:00</span>
      </div>
    </div>

    <!-- Metric 3: Final -->
    <div class="flex items-start gap-4 pt-6 md:pt-0 md:px-6">
      <div class="p-3.5 bg-crema-dark rounded-xl text-muted flex-shrink-0" aria-hidden="true">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
      </div>
      <div class="flex flex-col gap-0.5">
        <span class="text-[10px] font-black tracking-wider text-muted uppercase">{t("status.summary.end")}</span>
        <span class="text-base font-bold text-ink mt-1.5 leading-none">{t("status.summary.date.end")}</span>
        <span class="text-sm font-bold text-brand-red mt-1">20:00</span>
      </div>
    </div>

    <!-- Metric 4: Participacio -->
    <div class="flex items-start gap-4 pt-6 md:pt-0 md:px-6 last:pr-0">
      <div class="p-3.5 bg-crema-dark rounded-xl text-muted flex-shrink-0" aria-hidden="true">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"></path>
        </svg>
      </div>
      <div class="flex flex-col gap-1">
        <span class="text-[10px] font-black tracking-wider text-muted uppercase">{t("status.summary.participation")}</span>
        <span class="text-xl font-extrabold text-ink mt-1 leading-none">{formatNumber(totalVotes)}</span>
        <span class="text-xs text-muted font-medium mt-1">{t("status.summary.votesCast")}</span>
      </div>
    </div>

  </div>
</section>

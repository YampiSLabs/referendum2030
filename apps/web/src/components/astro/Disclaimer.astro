---
import { useTranslations } from "../../shared/i18n/translations";
import type { Locale } from "../../shared/i18n/translations";

interface Props {
  className?: string;
  isFloating?: boolean;
  lang?: Locale;
}

const { className = "", isFloating = false, lang = "ca" } = Astro.props;
const t = useTranslations(lang);
---

<div 
  class={`flex items-start gap-3.5 border-l-4 border-brand-gold bg-brand-gold-soft p-4.5 text-sm rounded-r-xl ${
    isFloating ? "shadow-premium max-w-xl" : ""
  } ${className}`}
  role="note" 
  aria-label={t("disclaimer.aria")}
>
  <!-- Info Icon -->
  <svg class="w-5.5 h-5.5 text-[#d97706] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 111.085 1.085l-.04.04m-2.137.882l4.07-4.07M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
  </svg>
  
  <div class="flex flex-col gap-0.5">
    <span class="font-outfit font-black text-ink leading-tight">{t("disclaimer.badge")}</span>
    <span class="text-muted leading-relaxed font-medium">
      {t("disclaimer.text")}
    </span>
  </div>
</div>

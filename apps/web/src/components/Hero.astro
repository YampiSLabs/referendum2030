---
import { Vote, HelpCircle } from "lucide-react";
import Disclaimer from "./Disclaimer.astro";
---

<section class="relative pt-12 pb-16 md:pt-20 md:pb-24 overflow-hidden">
  <!-- Glowing ambient light background decorations -->
  <div class="absolute -top-40 -left-40 w-96 h-96 rounded-full bg-brand-gold/10 blur-3xl -z-10 animate-pulse-glow" aria-hidden="true"></div>
  <div class="absolute top-20 right-0 w-80 h-80 rounded-full bg-brand-red/5 blur-3xl -z-10" aria-hidden="true"></div>

  <div class="container">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">

      <!-- Hero Left Content -->
      <div class="lg:col-span-6 flex flex-col gap-6">
        <div class="flex flex-col">
          <h1 class="font-outfit text-gray-900 font-extrabold text-[52px] md:text-[68px] tracking-tight leading-[1.05]">
            Referèndum
          </h1>
          <h1 class="font-outfit text-brand-red font-extrabold text-[52px] md:text-[68px] tracking-tight leading-[1.05] mt-1">
            2030
          </h1>
        </div>

        <div class="flex flex-col gap-4 mt-2 max-w-xl">
          <p class="text-gray-600 text-lg md:text-xl leading-relaxed font-semibold">
            Simulador cívic digital d'un referèndum fictici sobre el futur polític de Catalunya.
          </p>
          <p class="text-gray-900 text-lg md:text-xl font-extrabold leading-normal tracking-wide">
            Participa. Informa't. Decideix.
          </p>
        </div>

        <!-- Action Buttons -->
        <div class="flex flex-wrap gap-4 mt-4">
          <a class="btn min-w-[170px]" href="/votar">
            <Vote size={18} aria-hidden="true" />
            Vota Ara
          </a>
          <a class="btn btn-secondary min-w-[170px]" href="#com-funciona">
            <HelpCircle size={18} aria-hidden="true" />
            Com funciona
          </a>
        </div>

        <!-- Inline Fictional Disclaimer -->
        <div class="mt-4">
          <Disclaimer className="border-brand-gold/50 max-w-lg" />
        </div>
      </div>

      <!-- Hero Right Graphic Asset -->
      <div class="lg:col-span-6 flex justify-center lg:justify-end relative">
        <!-- Floating decorative circles -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[460px] h-[460px] border border-line/35 rounded-full -z-10 pointer-events-none" aria-hidden="true"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[340px] h-[340px] border border-brand-gold/15 rounded-full -z-10 pointer-events-none" aria-hidden="true"></div>

        <img
          src="/hero-ballot.png"
          alt="Urna de simulació de Referèndum 2030 sobre el fons del mapa de Catalunya amb pinzellades de color vermell i groc."
          class="max-w-full h-auto object-contain hover:scale-[1.02] transition-transform duration-500 drop-shadow-md"
          width="500"
          height="450"
          loading="eager"
        />
      </div>

    </div>
  </div>
</section>

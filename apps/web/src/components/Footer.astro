---
const base = (import.meta.env.BASE_URL || "/").replace(/\/$/, "");
const withBase = (path: string) => (path.startsWith("/") ? `${base}${path}` || "/" : path);

const navigationLinks = [
  { href: withBase("/"), label: "Inici" },
  { href: withBase("/#com-funciona"), label: "Com funciona" },
  { href: withBase("/votar"), label: "Votar" },
  { href: withBase("/resultats"), label: "Resultats" },
  { href: withBase("/transparencia"), label: "Transparencia" },
  { href: withBase("/faq"), label: "FAQ" },
];

const resourceLinks = [
  { href: withBase("/transparencia#metodologia"), label: "Metodologia" },
  { href: withBase("/resultats#dades-obertes"), label: "Dades obertes" },
  { href: withBase("/faq"), label: "Normes del simulador" },
  { href: withBase("/faq"), label: "Privacitat" },
  { href: withBase("/faq"), label: "Accessibilitat" },
];
---

<footer class="bg-crema-dark border-t border-line py-16 mt-20" aria-label="Peu de pagina">
  <div class="container grid gap-12 md:grid-cols-12">
    <div class="md:col-span-4 flex flex-col gap-4">
      <a href={withBase("/")} class="flex items-center gap-3">
        <div class="relative flex h-9 w-9 items-center justify-center rounded-full bg-white border border-brand-red" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="4" y="2" width="2.5" height="20" rx="1.25" fill="#d20a1e" />
            <rect x="9.5" y="2" width="2.5" height="20" rx="1.25" fill="#d20a1e" />
            <rect x="15" y="2" width="2.5" height="20" rx="1.25" fill="#d20a1e" />
            <rect x="20.5" y="2" width="2.5" height="20" rx="1.25" fill="#d20a1e" />
          </svg>
        </div>
        <div class="flex flex-col">
          <span class="font-outfit text-[10px] font-black tracking-[0.25em] text-ink uppercase leading-none">Referendum</span>
          <span class="font-outfit text-sm font-black text-brand-red leading-none mt-0.5">2030</span>
        </div>
      </a>
      <p class="text-sm text-muted leading-relaxed max-w-sm">
        Projecte fictici i educatiu per explorar un referendum digital accessible, transparent i centrat en el ciutada.
      </p>

      <div class="flex items-center gap-4 mt-2">
        <a href="https://twitter.com" target="_blank" rel="noopener noreferrer" class="text-muted hover:text-brand-red transition-colors" aria-label="Twitter fictici de Referendum 2030">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
        <a href="https://github.com/YampiSLabs/referendum2030" target="_blank" rel="noopener noreferrer" class="text-muted hover:text-brand-red transition-colors" aria-label="Repositori de codi a GitHub">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.137 20.162 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="md:col-span-5 grid grid-cols-2 gap-8">
      <div>
        <h3 class="font-outfit text-xs font-black tracking-wider text-ink uppercase mb-4">Navega</h3>
        <ul class="flex flex-col gap-2.5 text-sm font-semibold text-muted">
          {navigationLinks.map((link) => (
            <li><a href={link.href} class="hover:text-brand-red transition-colors duration-150">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="font-outfit text-xs font-black tracking-wider text-ink uppercase mb-4">Saber-ne mes</h3>
        <ul class="flex flex-col gap-2.5 text-sm font-semibold text-muted">
          {resourceLinks.map((link) => (
            <li><a href={link.href} class="hover:text-brand-red transition-colors duration-150">{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="md:col-span-3 flex flex-col gap-4">
      <h3 class="font-outfit text-xs font-black tracking-wider text-ink uppercase">Avis Legal</h3>
      <p class="text-xs text-muted leading-relaxed">
        Aquest projecte es una simulacio ficticia sense validesa legal ni vinculacio amb cap institucio publica.
      </p>
      <span class="text-xs text-muted/65 mt-2 block">
        (c) Referendum 2030 - Tots els drets reservats.
      </span>
    </div>
  </div>
</footer>
